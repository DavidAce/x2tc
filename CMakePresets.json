{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 24,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "default",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "X2TC_ENABLE_TESTS": "TRUE",
        "X2TC_CMAKE_DEBUG": "TRUE",
        "X2TC_PACKAGE_MANAGER": "find",
        "BUILD_SHARED_LIBS": "TRUE",
        "COMPILER_PROFILE_BUILD": "FALSE",
        "COMPILER_ENABLE_ASAN": "FALSE",
        "COMPILER_ENABLE_USAN": "FALSE",
        "COMPILER_ENABLE_PCH": "FALSE",
        "COMPILER_ENABLE_CCACHE": "FALSE",
        "CMAKE_VERBOSE_MAKEFILE": "FALSE",
        "CMAKE_MESSAGE_LOG_LEVEL": "STATUS",
        "CMAKE_INSTALL_PREFIX": "${sourceDir}/build/${presetName}/pkg-install",
        "CMAKE_C_STANDARD": "17",
        "CMAKE_CXX_STANDARD": "23",
        "CMAKE_CXX_STANDARD_REQUIRED": "TRUE",
        "CMAKE_CXX_EXTENSIONS": "FALSE",
        "CMAKE_POSITION_INDEPENDENT_CODE": "TRUE",
        "CMAKE_C_FLAGS_RELEASE_INIT": "-O3 -DNDEBUG -g -fdiagnostics-color=always",
        "CMAKE_CXX_FLAGS_RELEASE_INIT": "-O3 -DNDEBUG -g -fdiagnostics-color=always",
        "CMAKE_C_FLAGS_DEBUG_INIT": "-O0 -g -fstack-protector-strong -D_FORTIFY_SOURCE=2 -fno-omit-frame-pointer -fdiagnostics-color=always",
        "CMAKE_CXX_FLAGS_DEBUG_INIT": "-O0 -g -ftemplate-backtrace-limit=0 -fstack-protector-strong -D_FORTIFY_SOURCE=2 -fno-omit-frame-pointer -fdiagnostics-color=always",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "TRUE",
        "CMAKE_LINKER_TYPE": "MOLD",
        "CMAKE_SKIP_BUILD_RPATH": "FALSE",
        "CMAKE_BUILD_WITH_INSTALL_RPATH": "FALSE",
        "CMAKE_INSTALL_RPATH_USE_LINK_PATH": "TRUE"
      },
      "environment": {
        "NINJA_STATUS": "[run %r|beg %s|fin %f|tot %t|rate %o|time %e]:"
      }
    },
    {
      "name": "debug",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "BUILD_SHARED_LIBS": "TRUE",
        "CMAKE_VERBOSE_MAKEFILE": "TRUE",
        "CMAKE_MESSAGE_LOG_LEVEL": "VERBOSE",
        "X2TC_CMAKE_DEBUG": "TRUE"
      },
      "environment": {
        "VERBOSE": "1"
      }
    },
    {
      "name": "release",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "COMPILER_ENABLE_PCH": "TRUE",
        "COMPILER_ENABLE_CCACHE": "TRUE",
        "CMAKE_INTERPROCEDURAL_OPTIMIZATION": "TRUE"
      }
    },
    {
      "name": "haswell",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_C_FLAGS": "-march=haswell -mtune=haswell",
        "CMAKE_CXX_FLAGS": "-march=haswell -mtune=haswell"
      }
    },
    {
      "name": "find",
      "hidden": true,
      "cacheVariables": {
        "X2TC_PACKAGE_MANAGER": "find"
      }
    },
    {
      "name": "cmake",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_PROJECT_TOP_LEVEL_INCLUDES": "${sourceDir}/cmake/cmake_dependency_provider/cmake_provider.cmake",
        "X2TC_PACKAGE_MANAGER": "cmake",
        "CMAKE_FIND_PACKAGE_PREFER_CONFIG": "TRUE"
      }
    },
    {
      "name": "conan",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_PROJECT_TOP_LEVEL_INCLUDES": "${sourceDir}/cmake/conan2_dependency_provider/conan_provider.cmake",
        "X2TC_PACKAGE_MANAGER": "conan",
        "CMAKE_FIND_PACKAGE_PREFER_CONFIG": "TRUE"
      },
      "environment": {
        "PATH": "$env{HOME}/miniconda3/envs/dmrg/bin:$env{HOME}/anaconda3/envs/dmrg/bin:$env{HOME}/miniconda3/bin:$penv{PATH}"
      }
    },
    {
      "name": "debug-conan",
      "displayName": "Debug|conan",
      "inherits": [
        "conan",
        "debug",
        "default"
      ]
    },
    {
      "name": "release-find",
      "displayName": "Release|find",
      "inherits": [
        "find",
        "release",
        "default"
      ]
    },
    {
      "name": "release-cmake",
      "displayName": "Release|cmake",
      "inherits": [
        "cmake",
        "release",
        "default"
      ]
    },
    {
      "name": "release-conan",
      "displayName": "Release|conan",
      "inherits": [
        "conan",
        "release",
        "default"
      ]
    },
    {
      "name": "kraken",
      "displayName": "Release|march=haswell|conan",
      "inherits": [
        "haswell",
        "conan",
        "release",
        "default"
      ],
      "binaryDir": "${sourceDir}/build/Release",
      "cacheVariables": {
        "CMAKE_INSTALL_PREFIX": "$env{HOME}/x2tc-release-pkg-install",
        "CMAKE_INTERPROCEDURAL_OPTIMIZATION": "TRUE",
        "COMPILER_ENABLE_PCH": "TRUE",
        "COMPILER_ENABLE_CCACHE": "TRUE",
        "X2TC_ENABLE_32BIT": "FALSE",
        "X2TC_ENABLE_64BIT": "TRUE",
        "X2TC_ENABLE_80BIT": "FALSE",
        "X2TC_ENABLE_128BIT": "FALSE"
      }
    },
    {
      "name": "github-actions-cmake",
      "displayName": "GitHub Actions|cmake",
      "inherits": [
        "cmake",
        "release",
        "default"
      ],
      "binaryDir": "${sourceDir}/build/github-actions-cmake",
      "cacheVariables": {
        "X2TC_ENABLE_32BIT": "TRUE",
        "X2TC_ENABLE_64BIT": "TRUE",
        "X2TC_ENABLE_80BIT": "TRUE",
        "X2TC_ENABLE_128BIT": "TRUE"
      }
    },
    {
      "name": "github-actions-conan",
      "displayName": "GitHub Actions|conan",
      "inherits": [
        "conan",
        "release",
        "default"
      ],
      "binaryDir": "${sourceDir}/build/github-actions-conan",
      "cacheVariables": {
        "X2TC_ENABLE_32BIT": "TRUE",
        "X2TC_ENABLE_64BIT": "TRUE",
        "X2TC_ENABLE_80BIT": "TRUE",
        "X2TC_ENABLE_128BIT": "TRUE"
      }
    },
    {
      "name": "github-actions-conan-clang",
      "displayName": "GitHub Actions|conan|clang",
      "inherits": [
        "conan",
        "release",
        "default"
      ],
      "binaryDir": "${sourceDir}/build/github-actions-conan-clang",
      "cacheVariables": {
        "X2TC_ENABLE_32BIT": "TRUE",
        "X2TC_ENABLE_64BIT": "TRUE",
        "X2TC_ENABLE_80BIT": "TRUE",
        "X2TC_ENABLE_128BIT": "FALSE"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "debug-conan",
      "configurePreset": "debug-conan"
    },
    {
      "name": "release-find",
      "configurePreset": "release-find"
    },
    {
      "name": "release-cmake",
      "configurePreset": "release-cmake"
    },
    {
      "name": "release-conan",
      "configurePreset": "release-conan"
    },
    {
      "name": "kraken",
      "configurePreset": "kraken"
    },
    {
      "name": "github-actions-cmake",
      "configurePreset": "github-actions-cmake"
    },
    {
      "name": "github-actions-conan",
      "configurePreset": "github-actions-conan"
    },
    {
      "name": "github-actions-conan-clang",
      "configurePreset": "github-actions-conan-clang"
    }
  ],
  "testPresets": [
    {
      "name": "debug-conan",
      "configurePreset": "debug-conan",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "release-find",
      "configurePreset": "release-find",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "release-cmake",
      "configurePreset": "release-cmake",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "release-conan",
      "configurePreset": "release-conan",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "kraken",
      "configurePreset": "kraken",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "github-actions-cmake",
      "configurePreset": "github-actions-cmake",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "github-actions-conan",
      "configurePreset": "github-actions-conan",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "github-actions-conan-clang",
      "configurePreset": "github-actions-conan-clang",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
